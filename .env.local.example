# ============================================================
# jpradar v2 - Japan Used Market Arbitrage Tool
# ============================================================
# REQUIRED: 3つだけ用意すれば動く
# ============================================================

# 1. Supabase (無料プランでOK)
# https://supabase.com → New project → Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# 2. OpenAI (翻訳用 / gpt-4o-mini = 激安)
# https://platform.openai.com/api-keys
# 1000件翻訳しても約$0.10。月1ドル未満。
OPENAI_API_KEY=sk-...

# 3. Cron secret (自分で好きな文字列を設定)
# 例: openssl rand -hex 16
CRON_SECRET=your_random_secret_here

# App URL (Vercelデプロイ後に変更)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# eBay API → 不要！HTMLスクレイピングで代替
# PriceCharting → 不要！eBay成約価格で代替
# ============================================================

# ============================================================
# OPTIONAL: 将来追加
# ============================================================

